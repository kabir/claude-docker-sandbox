# Claude Code Authentication
# The sandbox uses your existing ~/.claude configuration automatically.
# You only need to set these if you want to override your existing settings:

# Vertex AI (Google Cloud) - usually inherited from your host environment
CLAUDE_CODE_USE_VERTEX=1
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id

# If using standard Anthropic API instead (uncomment if needed):
# ANTHROPIC_API_KEY=your-api-key-here

# Git Configuration (optional)
# Used for commits made inside the container
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=your.email@example.com
GIT_COMMITTER_NAME=Your Name
GIT_COMMITTER_EMAIL=your.email@example.com

# NOTE: No projects are mounted by default
# Use the --mount flag to mount directories on-demand:
#   ./claude-pod.sh -m ~/myproject:/workspace/myproject shell

# Network: Container has full network access (required for Claude Code to work)
# - Claude needs to connect to Anthropic/Vertex AI APIs
# - MCP servers run on host but need network to communicate
# - Package managers need internet (npm, pip, apt)
# Security comes from container isolation and copy mode, not network restrictions
